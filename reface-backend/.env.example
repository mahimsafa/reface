# Database
DATABASE_URL=sqlite:///./reface.db
# DATABASE_URL=postgresql://user:password@localhost:5432/reface

# Redis (Celery broker & result backend)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# REDIS_URL=rediss://default:password@host.upstash.io:6379
# CELERY_BROKER_URL=rediss://default:password@host.upstash.io:6379
# CELERY_RESULT_BACKEND=rediss://default:password@host.upstash.io:6379

# ML model paths
MODEL_PATH=models/inswapper_128.onnx
CODEFORMER_PATH=models/CodeFormer/codeformer.pth

# Local storage directories (deprecated — kept for legacy)
UPLOAD_DIR=uploads
OUTPUT_DIR=uploads/output
IMAGES_DIR=uploads/images

# Server
HOST=0.0.0.0
PORT=5000

# ML device (cpu, mps, cuda)
DEVICE=cpu

# S3-compatible object storage (e.g., Cloudflare R2)
S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=<your-access-key>
S3_SECRET_ACCESS_KEY=<your-secret-key>
S3_REGION=auto
S3_BUCKET_NAME=reface
S3_PUBLIC_URL=https://pub-<hash>.r2.dev
